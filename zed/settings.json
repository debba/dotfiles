// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    }
  },
  "edit_predictions": {
    "provider": "copilot",
  },
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
        },
      },
      "enable_lsp_tasks": true,
    },
  },
  "preview_tabs": {
    // Whether preview tabs should be enabled.
    // Preview tabs allow you to open files in preview mode, where they close automatically
    // when you switch to another file unless you explicitly pin them.
    // This is useful for quickly viewing files without cluttering your workspace.

    "enabled": false,

    // Whether to open files in preview mode when selected from the file finder.

    "enable_preview_from_file_finder": false,
  },
  "icon_theme": "Catppuccin Macchiato",
  "git_panel": {
    "tree_view": true,
  },
  "soft_wrap": "editor_width",
  "format_on_save": "on",
  "agent": {
    "tool_permissions": {
      "default": "allow",
    },
    "default_model": {
      "enable_thinking": false,
      "provider": "openrouter",
      "model": "openai/gpt-5.3-chat",
    },
    "commit_message_model": {
      "provider": "openai",
      "model": "gpt-4o"
    },
    "model_parameters": [],
  },
  "context_servers": {
    "mcp-server-github": {
      "enabled": true,
      "remote": false,
      "settings": {},
    },
  },
  "base_keymap": "VSCode",
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "buffer_font_fallbacks": [
    "Droid Sans Mono",
    "monospace",
    "monospace",
    "Droid Sans Fallback",
  ],
  "buffer_font_family": "Jetbrains Mono",
  "auto_indent_on_paste": true,
  "show_edit_predictions": true,
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark",
  },
}
